{
  "name": "action-api-cli",
  "version": "0.1.0",
  "description": "Action API CLI",
  "main": "main.js",
  "bin": {
    "action-api": "./main.js"
  },
  "type": "module",
  "types": "@types/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rm -rf @types && tsc",
    "lint": "xo",
    "format": "xo --fix",
    "test": "node --test",
    "prepublishOnly": "npm run format && npm run build"
  },
  "dependencies": {
    "esprima-next": "^6.0.3",
    "lodash.camelcase": "^4.3.0"
  },
  "devDependencies": {
    "@types/lodash.camelcase": "^4.3.9",
    "@types/node": "^25.5.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "typescript": "^6.0.2",
    "xo": "^2.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/madakaheri/action-api-cli.git"
  },
  "bugs": {
    "url": "https://github.com/madakaheri/action-api-cli/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
